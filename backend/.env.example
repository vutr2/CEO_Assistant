# ============================================================================
# CEO AI ASSISTANT - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env file to version control
# ============================================================================

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=5000
HOST=localhost

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ceo-ai-assistant

# Alternative: MongoDB Atlas
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ceo-ai-assistant?retryWrites=true&w=majority

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate a strong secret key (use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Refresh token configuration
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# AI SERVICE CONFIGURATION
# ============================================================================
# OpenAI API Key (for GPT models)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# AI Model Configuration
AI_MODEL=gpt-4
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# For production, use your actual domain:
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# RATE LIMITING
# ============================================================================
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# FILE UPLOAD
# ============================================================================
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=./uploads

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================
# SMTP Configuration for sending emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@ceoai.com

# ============================================================================
# REDIS CONFIGURATION (Optional - for caching and sessions)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Redis Cloud / Upstash (if using cloud service)
# REDIS_URL=redis://username:password@host:port

# ============================================================================
# LOGGING
# ============================================================================
# Log level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
# Session secret (use a strong random string)
SESSION_SECRET=your-session-secret-change-this-in-production

# ============================================================================
# PAYMENT CONFIGURATION (Optional - for billing features)
# ============================================================================
# Stripe API Keys
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# CLOUD STORAGE (Optional - for file uploads)
# ============================================================================
# AWS S3 Configuration
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
# Google Analytics
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# Mixpanel
# MIXPANEL_TOKEN=your-mixpanel-token

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================
# Slack Notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SendGrid (Alternative email service)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Twilio (For SMS notifications)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# NOTES
# ============================================================================
# 1. Always use strong, randomly generated secrets for JWT and session keys
# 2. Keep your .env file private and never commit it to version control
# 3. Add .env to your .gitignore file
# 4. Use different values for development, staging, and production environments
# 5. Rotate secrets regularly for enhanced security
# ============================================================================
